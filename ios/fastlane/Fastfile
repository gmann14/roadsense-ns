require "fileutils"
require "shellwords"

default_platform(:ios)

PROJECT_PATH = "RoadSenseNS.xcodeproj"
SCHEME = "RoadSenseNS"
DEFAULT_APP_IDENTIFIER = "ca.roadsense.ios"

def required_env(name)
  value = ENV[name].to_s.strip
  UI.user_error!("Missing required environment variable: #{name}") if value.empty?
  value
end

def optional_env(name)
  value = ENV[name].to_s
  value.empty? ? nil : value
end

def truthy_env?(name)
  %w[1 true yes y].include?(ENV[name].to_s.strip.downcase)
end

def release_configuration
  ENV.fetch("IOS_RELEASE_CONFIGURATION", "Staging Release")
end

def release_channel
  release_configuration.include?("Production") ? "Production" : "Staging"
end

def release_xcconfig_path
  File.expand_path("../Config/RoadSenseNS.#{release_channel}.secrets.xcconfig", __dir__)
end

def app_identifier
  ENV.fetch("ROAD_SENSE_APP_IDENTIFIER", DEFAULT_APP_IDENTIFIER)
end

def asc_private_key_path
  path = optional_env("APPLE_ASC_API_PRIVATE_KEY_PATH")
  return path if path

  key_content = optional_env("APPLE_ASC_API_PRIVATE_KEY")
  UI.user_error!("Set APPLE_ASC_API_PRIVATE_KEY_PATH or APPLE_ASC_API_PRIVATE_KEY") unless key_content

  key_id = required_env("APPLE_ASC_API_KEY_ID")
  output_dir = File.expand_path("../build/secrets", __dir__)
  FileUtils.mkdir_p(output_dir)
  path = File.join(output_dir, "AuthKey_#{key_id}.p8")
  File.write(path, key_content)
  File.chmod(0o600, path)
  path
end

def asc_api_key
  app_store_connect_api_key(
    key_id: required_env("APPLE_ASC_API_KEY_ID"),
    issuer_id: required_env("APPLE_ASC_API_ISSUER_ID"),
    key_filepath: asc_private_key_path,
    duration: 1200,
    in_house: false
  )
end

def write_release_xcconfig
  team_id = required_env("APPLE_TEAM_ID")
  mapbox_token = required_env("MAPBOX_ACCESS_TOKEN")
  api_key = optional_env("ROAD_SENSE_PUBLIC_API_KEY") || optional_env("SUPABASE_ANON_KEY")
  api_base_url = optional_env("API_BASE_URL")
  sentry_dsn = optional_env("SENTRY_DSN")
  enable_pothole_photos = ENV.fetch("ENABLE_POTHOLE_PHOTOS", "NO")

  lines = [
    "// Generated by fastlane. This file is ignored by git.",
    "DEVELOPMENT_TEAM = #{team_id}",
    "ROAD_SENSE_APP_BUNDLE_IDENTIFIER = #{app_identifier}",
    "MAPBOX_ACCESS_TOKEN = #{mapbox_token}",
    "ENABLE_POTHOLE_PHOTOS = #{enable_pothole_photos}"
  ]
  lines << "API_BASE_URL = #{api_base_url}" if api_base_url
  lines << "SUPABASE_ANON_KEY = #{api_key}" if api_key
  lines << "SENTRY_DSN = #{sentry_dsn}" if sentry_dsn

  File.write(release_xcconfig_path, "#{lines.join("\n")}\n")
  UI.message("Wrote #{release_channel} release xcconfig")
end

def build_number
  optional_env("IOS_BUILD_NUMBER") || optional_env("GITHUB_RUN_NUMBER") || Time.now.utc.strftime("%Y%m%d%H%M")
end

def xcode_auth_args
  key_path = asc_private_key_path
  [
    "-allowProvisioningUpdates",
    "-authenticationKeyPath #{Shellwords.escape(key_path)}",
    "-authenticationKeyID #{Shellwords.escape(required_env("APPLE_ASC_API_KEY_ID"))}",
    "-authenticationKeyIssuerID #{Shellwords.escape(required_env("APPLE_ASC_API_ISSUER_ID"))}",
    "DEVELOPMENT_TEAM=#{Shellwords.escape(required_env("APPLE_TEAM_ID"))}",
    "PRODUCT_BUNDLE_IDENTIFIER=#{Shellwords.escape(app_identifier)}",
    "CURRENT_PROJECT_VERSION=#{Shellwords.escape(build_number)}",
    "COMPILER_INDEX_STORE_ENABLE=NO",
    "ENABLE_PREVIEWS=NO"
  ].join(" ")
end

platform :ios do
  desc "Build a signed release IPA. Defaults to Staging Release for internal TestFlight."
  lane :build_release do
    asc_api_key
    write_release_xcconfig
    sh("xcodegen generate")

    build_app(
      project: PROJECT_PATH,
      scheme: SCHEME,
      configuration: release_configuration,
      clean: true,
      archive_path: "build/archives/RoadSenseNS-#{build_number}.xcarchive",
      output_directory: "build/ipas",
      output_name: "RoadSenseNS-#{build_number}.ipa",
      export_method: "app-store",
      export_team_id: required_env("APPLE_TEAM_ID"),
      include_symbols: true,
      include_bitcode: false,
      xcargs: xcode_auth_args,
      export_xcargs: xcode_auth_args,
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        teamID: required_env("APPLE_TEAM_ID")
      }
    )
  end

  desc "Upload an existing IPA to internal TestFlight without external beta submission."
  lane :upload_ipa do |options|
    api_key = asc_api_key
    ipa = options[:ipa] || optional_env("IPA_PATH")
    UI.user_error!("Pass ipa:/path/to/app.ipa or set IPA_PATH") unless ipa

    upload_to_testflight(
      api_key: api_key,
      app_identifier: app_identifier,
      ipa: ipa,
      skip_submission: true,
      distribute_external: false,
      skip_waiting_for_build_processing: true,
      changelog: optional_env("TESTFLIGHT_CHANGELOG") || "Internal RoadSense NS field-test build."
    )
  end

  desc "Build a signed release IPA and upload it to internal TestFlight."
  lane :testflight do
    build_release

    if truthy_env?("SKIP_TESTFLIGHT_UPLOAD")
      UI.important("SKIP_TESTFLIGHT_UPLOAD is set; IPA was built but not uploaded.")
      next
    end

    ipa = File.expand_path("build/ipas/RoadSenseNS-#{build_number}.ipa")
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: app_identifier,
      ipa: ipa,
      skip_submission: true,
      distribute_external: false,
      skip_waiting_for_build_processing: true,
      changelog: optional_env("TESTFLIGHT_CHANGELOG") || "Internal RoadSense NS field-test build."
    )
  end
end
